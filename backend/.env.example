# ============================
# CONFIGURACIÓN DE ConverFast
# ============================

# Puerto del servidor
PORT=3001

# Entorno: development | production
NODE_ENV=development

# URL del frontend (CORS)
FRONTEND_URL=http://localhost:5173

# En producción:
# FRONTEND_URL=https://tudominio.com

# Tiempo de expiración de archivos (en minutos)
FILE_EXPIRY_MINUTES=60

# Tamaño máximo de archivo (en MB)
MAX_FILE_SIZE_MB=100

# Directorio temporal para archivos
UPLOAD_DIR=./tmp/uploads
OUTPUT_DIR=./tmp/outputs

# Clave secreta para rate limiting (opcional)
SECRET_KEY=tu_clave_secreta_aqui_cambiala

# API de Google Vision (OCR avanzado) - OPCIONAL
# GOOGLE_VISION_API_KEY=

# Webhook de notificaciones (opcional)
# WEBHOOK_URL=

# Google Analytics Measurement ID (opcional)
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
